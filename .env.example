# Aventrex Digitals API — blog posts and pricing plans load live in the browser on Hostinger (static export).
# Copy to .env.production before running `npm run build:hostinger`.

AVENTREX_API_URL=https://aventrexdigital.com
NEXT_PUBLIC_AVENTREX_API_URL=https://aventrexdigital.com
AVENTREX_PRODUCT_SLUG=venqora-ehr
# EHR review directory profile URLs (optional — shown on homepage when set)
# NEXT_PUBLIC_G2_URL=https://www.g2.com/products/venqora-ehr/reviews
# NEXT_PUBLIC_CAPTERRA_URL=https://www.capterra.com/p/...
# NEXT_PUBLIC_SOFTWARE_ADVICE_URL=https://www.softwareadvice.com/...
# NEXT_PUBLIC_GETAPP_URL=https://www.getapp.com/...

# Google Search Console / Bing Webmaster verification (meta tag content values)
# GOOGLE_SITE_VERIFICATION=your-google-verification-code
# BING_SITE_VERIFICATION=your-bing-verification-code
