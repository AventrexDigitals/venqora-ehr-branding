# Local dev — copy to .env.local (loaded by `npm run dev`)
# Use local Aventrex Digitals when running both apps side by side.

AVENTREX_API_URL=http://localhost:3000
NEXT_PUBLIC_AVENTREX_API_URL=http://localhost:3000
AVENTREX_PRODUCT_SLUG=venqora-ehr
NEXT_PUBLIC_AVENTREX_PRODUCT_SLUG=venqora-ehr

# Or point at production API instead:
# AVENTREX_API_URL=https://aventrexdigital.com
# NEXT_PUBLIC_AVENTREX_API_URL=https://aventrexdigital.com
